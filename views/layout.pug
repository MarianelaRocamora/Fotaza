html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1')
    title Fotaza - #{title || 'Inicio'}
    link(rel='stylesheet' href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css')
    link(rel='stylesheet' href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css')
    style.
      body { background-color: #f8f9fa; }
      .navbar-brand { font-weight: bold; font-size: 1.5rem; }
      .card-img-top { object-fit: cover; height: 250px; }
      .pub-card { transition: transform 0.2s; }
      .pub-card:hover { transform: translateY(-3px); box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
  body
    nav.navbar.navbar-dark.bg-dark.px-3
      a.navbar-brand(href='/home') 📷 Fotaza
      form.d-flex.mx-auto(method='GET' action='/buscar' style='width:40%')
        input.form-control.me-2(type='text' name='q' placeholder='Buscar publicaciones...')
        button.btn.btn-outline-light(type='submit')
          i.bi.bi-search
      ul.navbar-nav.flex-row.gap-3.align-items-center
        if usuario
          li.nav-item
            a.nav-link(href=`/perfil/${usuario.id}`)
              i.bi.bi-person-circle
              |  #{usuario.nombre}
          li.nav-item
            a.nav-link(href='/publicacion/nueva')
              i.bi.bi-plus-circle
              |  Nueva
          li.nav-item
            a.nav-link(href='/logout')
              i.bi.bi-box-arrow-right
              |  Salir

    .container.mt-4
      if exito
        .alert.alert-success #{exito}
      if error
        .alert.alert-danger #{error}
      block content

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js')