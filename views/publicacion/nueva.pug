extends ../layout

block content
  .container.py-4
    .row.justify-content-center
      .col-lg-7.col-md-9

        .card.shadow-sm
          .card-header.bg-primary.text-white
            h4.mb-0
              i.bi.bi-camera-fill.me-2
              | Nueva publicación

          .card-body.p-4

            if error
              .alert.alert-danger.d-flex.align-items-center.gap-2
                i.bi.bi-exclamation-triangle-fill
                span= error

            form#formPublicacion(method='POST' action='/publicacion/nueva' enctype='multipart/form-data')

              //- ─── Título ─────────────────────────────
              .mb-3
                label.form-label.fw-semibold(for='titulo')
                  | Título
                  span.text-danger  *
                input#titulo.form-control(
                  type='text'
                  name='titulo'
                  placeholder='Ej: Atardecer en las sierras'
                  required
                  value=valores && valores.titulo ? valores.titulo : ''
                )

              //- ─── Descripción ────────────────────────
              .mb-3
                label.form-label.fw-semibold(for='descripcion')
                  | Descripción
                  span.text-muted.small.ms-1 (opcional)
                textarea#descripcion.form-control(
                  name='descripcion'
                  rows='3'
                  placeholder='Contá algo sobre esta publicación...'
                )= valores && valores.descripcion ? valores.descripcion : ''

              //- ─── Imágenes ───────────────────────────
              .mb-3
                label.form-label.fw-semibold
                  | Imágenes
                  span.text-danger  *

                input#inputImagenes(
                  type='file'
                  name='imagenes'
                  multiple
                  accept='image/jpeg,image/jpg,image/png,image/gif,image/webp'
                  style='display:none'
                )

                button.btn.btn-outline-primary.w-100.mb-2(type='button' onclick='document.getElementById("inputImagenes").click()')
                  i.bi.bi-plus-circle.me-2
                  | Agregar imagen(es)

                .form-text.mb-2
                  i.bi.bi-info-circle.me-1
                  | Podés agregar varias imágenes de a una o varias a la vez. Mínimo 1. Máximo 5MB por imagen.

                #listaImagenes.d-flex.flex-wrap.gap-2

              //- ─── Etiquetas ──────────────────────────
              .mb-3
                label.form-label.fw-semibold(for='etiquetas')
                  | Etiquetas
                  span.text-danger  *
                input#etiquetas.form-control(
                  type='text'
                  name='etiquetas'
                  placeholder='Ej: paisaje, naturaleza, montaña'
                  required
                  value=valores && valores.etiquetas ? valores.etiquetas : ''
                )
                .form-text
                  i.bi.bi-tag.me-1
                  | Separalas con comas. Al menos una es obligatoria.

              //- ─── Licencia ───────────────────────────
              .mb-3
                label.form-label.fw-semibold(for='licencia') Licencia
                select#licencia.form-select(name='licencia' onchange='toggleMarca(this.value)')
                  option(value='sin_copyright') 🌐 Sin copyright (contenido público)
                  option(value='copyright') 🔒 Con copyright (contenido protegido)

              //- ─── Marca de agua ───────────────────────
              #marcaDiv.mb-3(style='display:none')
                .card.bg-light.border-0
                  .card-body.py-3
                    label.form-label.fw-semibold Marca de agua
                    select.form-select.mb-2(name='marca_de_agua')
                      option(value='true') ✅ Aplicar marca de agua
                      option(value='false') ❌ Sin marca de agua
                    input.form-control(
                      type='text'
                      name='texto_marca'
                      placeholder='Ej: © María González 2026'
                      value=valores && valores.texto_marca ? valores.texto_marca : ''
                    )
                    .form-text Este texto aparecerá sobre la imagen como marca de agua.

              //- ─── Botones ────────────────────────────
              .d-flex.gap-2.mt-4
                button.btn.btn-primary.flex-grow-1(type='submit')
                  i.bi.bi-cloud-upload.me-2
                  | Publicar
                a.btn.btn-outline-secondary(href='/home')
                  i.bi.bi-arrow-left.me-1
                  | Cancelar

  script.
    let archivosAcumulados = new DataTransfer();

    document.getElementById('inputImagenes').addEventListener('change', function(e) {
      const nuevos = Array.from(e.target.files);
      const MAX_SIZE = 5 * 1024 * 1024;
      const tiposPermitidos = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/webp'];

      nuevos.forEach(function(file) {
        if (!tiposPermitidos.includes(file.type)) {
          alert('Solo se permiten imágenes jpg, png, gif, webp: ' + file.name);
          return;
        }
        if (file.size > MAX_SIZE) {
          alert('La imagen supera 5MB: ' + file.name);
          return;
        }
        const nombres = Array.from(archivosAcumulados.files).map(function(f) { return f.name; });
        if (!nombres.includes(file.name)) {
          archivosAcumulados.items.add(file);
        }
      });

      document.getElementById('inputImagenes').files = archivosAcumulados.files;
      renderLista();
    });

    function renderLista() {
      var lista = document.getElementById('listaImagenes');
      lista.innerHTML = '';

      if (archivosAcumulados.files.length === 0) {
        lista.innerHTML = '<p class="text-muted small">Ninguna imagen seleccionada aún.</p>';
        return;
      }

      Array.from(archivosAcumulados.files).forEach(function(file, index) {
        var reader = new FileReader();
        reader.onload = function(e) {
          var div = document.createElement('div');
          div.className = 'position-relative';
          div.style.cssText = 'width:90px;';
          div.innerHTML =
            '<img src="' + e.target.result + '" style="width:90px;height:90px;object-fit:cover;border-radius:8px;border:2px solid #dee2e6">' +
            '<button type="button" onclick="quitarImagen(' + index + ')" ' +
            'style="position:absolute;top:-6px;right:-6px;width:22px;height:22px;border-radius:50%;' +
            'background:#dc3545;color:white;border:none;font-size:12px;line-height:1;cursor:pointer;">✕</button>' +
            '<p class="text-center mt-1" style="font-size:10px;word-break:break-all;">' + file.name.substring(0, 12) + '...</p>';
          lista.appendChild(div);
        };
        reader.readAsDataURL(file);
      });
    }

    function quitarImagen(index) {
      var nueva = new DataTransfer();
      Array.from(archivosAcumulados.files).forEach(function(file, i) {
        if (i !== index) nueva.items.add(file);
      });
      archivosAcumulados = nueva;
      document.getElementById('inputImagenes').files = archivosAcumulados.files;
      renderLista();
    }

    function toggleMarca(valor) {
      document.getElementById('marcaDiv').style.display = valor === 'copyright' ? 'block' : 'none';
    }
