extends ../layout

block content
  .container.py-4
    .row.justify-content-center
      .col-lg-7.col-md-9

        .card.shadow-sm
          .card-header.bg-warning.text-dark
            h4.mb-0
              i.bi.bi-pencil-fill.me-2
              | Editar publicación

          .card-body.p-4

            //- ─── Error ──────────────────────────────────
            if error
              .alert.alert-danger.d-flex.align-items-center.gap-2
                i.bi.bi-exclamation-triangle-fill
                span= error

            form(method='POST' action=`/publicacion/${publicacion.id_publicacion}/editar` enctype='multipart/form-data')

              //- ─── Título ─────────────────────────────
              .mb-3
                label.form-label.fw-semibold(for='titulo')
                  | Título
                  span.text-danger  *
                input#titulo.form-control(
                  type='text'
                  name='titulo'
                  required
                  placeholder='Ej: Atardecer en las sierras'
                  value=publicacion.titulo
                )

              //- ─── Descripción ────────────────────────
              .mb-3
                label.form-label.fw-semibold(for='descripcion')
                  | Descripción
                  span.text-muted.small.ms-1 (opcional)
                textarea#descripcion.form-control(
                  name='descripcion'
                  rows='3'
                  placeholder='Contá algo sobre esta publicación...'
                )= publicacion.descripcion || ''

              //- ─── Imágenes actuales ───────────────────
              .mb-3
                label.form-label.fw-semibold
                  i.bi.bi-images.me-1
                  | Imágenes actuales
                if imagenes && imagenes.length > 0
                  .d-flex.gap-2.flex-wrap
                    each img in imagenes
                      .position-relative
                        img(
                          src=img.foto
                          alt='Imagen de la publicación'
                          style='width:100px; height:100px; object-fit:cover; border-radius:8px; border:2px solid #dee2e6'
                        )
                        if img.licencia === 'copyright'
                          span.badge.bg-danger.position-absolute(style='top:4px;left:4px;font-size:10px') © CR
                        else
                          span.badge.bg-success.position-absolute(style='top:4px;left:4px;font-size:10px') Libre
                else
                  p.text-muted.small Sin imágenes actuales.

              //- ─── Agregar más imágenes ────────────────
              .mb-3
                label.form-label.fw-semibold(for='imagenes')
                  i.bi.bi-plus-circle.me-1
                  | Agregar más imágenes
                  span.text-muted.small.ms-1 (opcional)
                input#imagenes.form-control(
                  type='file'
                  name='imagenes'
                  multiple
                  accept='image/jpeg,image/jpg,image/png,image/gif,image/webp'
                )
                .form-text
                  i.bi.bi-info-circle.me-1
                  | Las imágenes nuevas se agregarán a las existentes. Formatos: jpg, png, gif, webp. Máximo 5MB por imagen.

              //- ─── Aviso si reemplaza ──────────────────
              .alert.alert-warning.py-2.small
                i.bi.bi-exclamation-triangle.me-1
                | Si subís nuevas imágenes, se borrarán los votos y comentarios de las imágenes anteriores.

              //- ─── Etiquetas ──────────────────────────
              .mb-3
                label.form-label.fw-semibold(for='etiquetas')
                  | Etiquetas
                  span.text-danger  *
                input#etiquetas.form-control(
                  type='text'
                  name='etiquetas'
                  required
                  placeholder='Ej: paisaje, naturaleza, montaña'
                  value=etiquetas
                )
                .form-text
                  i.bi.bi-tag.me-1
                  | Separalas con comas. Al menos una es obligatoria.

              //- ─── Licencia ───────────────────────────
              .mb-3
                label.form-label.fw-semibold(for='licencia') Licencia
                select#licencia.form-select(name='licencia' onchange='toggleMarca(this.value)')
                  option(value='sin_copyright') 🌐 Sin copyright (contenido público)
                  option(value='copyright') 🔒 Con copyright (contenido protegido)

              //- ─── Marca de agua (condicional) ────────
              #marcaDiv.mb-3(style='display:none')
                .card.bg-light.border-0
                  .card-body.py-3
                    label.form-label.fw-semibold Marca de agua
                    select.form-select.mb-2(name='marca_de_agua')
                      option(value='true') ✅ Aplicar marca de agua
                      option(value='false') ❌ Sin marca de agua
                    input.form-control(
                      type='text'
                      name='texto_marca'
                      placeholder='Ej: © María González 2026'
                    )
                    .form-text Este texto aparecerá sobre la imagen como marca de agua.

              //- ─── Botones ────────────────────────────
              .d-flex.gap-2.mt-4
                button.btn.btn-warning.flex-grow-1(type='submit')
                  i.bi.bi-save.me-2
                  | Guardar cambios
                a.btn.btn-outline-secondary(href=`/perfil/${usuario.id}`)
                  i.bi.bi-arrow-left.me-1
                  | Cancelar

  script.
    function toggleMarca(valor) {
      var div = document.getElementById('marcaDiv');
      div.style.display = valor === 'copyright' ? 'block' : 'none';
    }
