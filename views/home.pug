html
  head
    title Home - Fotaza
  body
    h1 Bienvenido #{usuario.nombre}!

    if exito
      p(style='color:green') ✅ #{exito}
    if error
      p(style='color:red') ❌ #{error}

    p Estás logueado correctamente
    a(href='/publicacion/nueva') Crear nueva publicación
    br
    a(href='/logout') Cerrar sesión

    hr

    h2 ⭐ Destacadas
    if destacadas && destacadas.length > 0
      each pub in destacadas
        div(style='border:1px solid #ccc; margin:10px; padding:10px')
          h3= pub.titulo
          if pub.foto
            img(src=pub.foto width='200')
          if pub.descripcion
            p= pub.descripcion
          p Promedio: #{parseFloat(pub.promedio || 0).toFixed(1)} ⭐ (#{pub.total_votos || 0} votos)
          form(method='POST' action='/votar')
            input(type='hidden' name='id_imagen' value=pub.id_imagen)
            input(type='hidden' name='redirect_to' value='/home')
            select(name='valoracion')
              option(value='1') 1 ⭐
              option(value='2') 2 ⭐
              option(value='3') 3 ⭐
              option(value='4') 4 ⭐
              option(value='5') 5 ⭐
            button(type='submit') Votar
          hr
          h4 Comentarios
          if pub.comentarios && pub.comentarios.length > 0
            each c in pub.comentarios
              div(style='margin:5px 0; padding:5px; background:#f9f9f9')
                p
                  strong= c.comentador ? c.comentador.nombre : 'Usuario'
                  |  · #{new Date(c.fecha_comentario).toLocaleDateString('es-AR')}
                p= c.texto
          else
            p Sé el primero en comentar.
          form(method='POST' action='/comentar')
            input(type='hidden' name='id_imagen' value=pub.id_imagen)
            input(type='hidden' name='redirect_to' value='/home')
            textarea(name='texto' rows='2' placeholder='Escribí un comentario...' required)
            br
            button(type='submit') Comentar
    else
      p Aún no hay publicaciones para descubrir.

    hr

