extends layout

block content

  if esAnonimo
    .alert.alert-info.d-flex.align-items-center.gap-2.mb-4
      i.bi.bi-info-circle-fill
      span
        | Estás viendo contenido público. 
        a(href='/login') Iniciá sesión
        |  o 
        a(href='/registro') registrate
        |  para votar, comentar y ver todo el contenido.

  mixin tarjeta(pub)
    .col
      .card.pub-card.h-100.shadow-sm
        .card-body
          h5.card-title= pub.titulo
          p.small.text-muted
            i.bi.bi-person
            |  
            a(href=`/perfil/${pub.id_usuario}`) #{pub.nombre_autor} #{pub.apellido_autor}
          if pub.descripcion
            p.card-text.text-muted.small= pub.descripcion
          if pub.etiquetas
            p.small.mb-2
              i.bi.bi-tags
              |  
              each tag in pub.etiquetas.split(', ')
                span.badge.bg-secondary.me-1= tag
          .d-flex.align-items-center.gap-2.mb-3
            span.badge.bg-warning.text-dark ⭐ #{parseFloat(pub.promedio || 0).toFixed(1)}
            span.text-muted.small (#{pub.total_votos || 0} votos totales)

        //- ─── Imágenes de la publicación ─────────────────
        if pub.imagenes && pub.imagenes.length > 0
          each img in pub.imagenes
            .border-top.p-3
              img.img-fluid.rounded.mb-2(
                src=img.foto
                alt=pub.titulo
                style='width:100%;max-height:260px;object-fit:cover'
              )
              if img.licencia === 'copyright'
                span.badge.bg-danger.mb-2 🔒 Copyright
              else
                span.badge.bg-success.mb-2 🌐 Sin copyright

              //- ─── Votar ──────────────────────────────
              if esAnonimo
                p.text-muted.small.mb-2
                  i.bi.bi-lock
                  |  
                  a(href='/login') Iniciá sesión
                  |  para votar
              else
                form.d-flex.gap-2.mb-2(method='POST' action='/votar')
                  input(type='hidden' name='id_imagen' value=img.id_imagen)
                  input(type='hidden' name='redirect_to' value='/home')
                  select.form-select.form-select-sm(name='valoracion' style='width:80px')
                    option(value='1') 1 ⭐
                    option(value='2') 2 ⭐
                    option(value='3') 3 ⭐
                    option(value='4') 4 ⭐
                    option(value='5') 5 ⭐
                  button.btn.btn-sm.btn-outline-warning(type='submit') Votar

              //- ─── Comentarios ────────────────────────
              h6.small.fw-bold
                i.bi.bi-chat.me-1
                | Comentarios
              if img.comentario_clausurado
                p.text-muted.small 🔒 Comentarios cerrados.
              if img.comentarios && img.comentarios.length > 0
                each c in img.comentarios
                  .mb-1.p-2.bg-light.rounded.small
                    strong= c.comentador ? c.comentador.nombre : 'Usuario'
                    span.text-muted  · #{new Date(c.fecha_comentario).toLocaleDateString('es-AR')}
                    p.mb-0= c.texto
              else
                if !img.comentario_clausurado
                  p.text-muted.small Sé el primero en comentar.

              if !img.comentario_clausurado
                if esAnonimo
                  p.text-muted.small
                    i.bi.bi-lock
                    |  
                    a(href='/login') Iniciá sesión
                    |  para comentar
                else
                  form.mt-2(method='POST' action='/comentar')
                    input(type='hidden' name='id_imagen' value=img.id_imagen)
                    input(type='hidden' name='redirect_to' value='/home')
                    .input-group.input-group-sm
                      input.form-control(type='text' name='texto' placeholder='Escribí un comentario...' required)
                      button.btn.btn-outline-secondary(type='submit') Comentar

  if !esAnonimo && siguiendo && siguiendo.length > 0
    h2.mb-4 👥 Publicaciones de usuarios que sigo
    .row.row-cols-1.row-cols-md-3.g-4.mb-5
      each pub in siguiendo
        +tarjeta(pub)
    hr

  h2.mb-4 ⭐ Destacadas
  if destacadas && destacadas.length > 0
    .row.row-cols-1.row-cols-md-3.g-4.mb-5
      each pub in destacadas
        +tarjeta(pub)
  else
    p.text-muted Aún no hay publicaciones destacadas.
  hr

  h2.mb-4 🕐 Recientes
  if recientes && recientes.length > 0
    .row.row-cols-1.row-cols-md-3.g-4.mb-5
      each pub in recientes
        +tarjeta(pub)
  else
    p.text-muted Aún no hay publicaciones recientes.
  hr

  h2.mb-4 🔍 Descubrí más
  if descubri && descubri.length > 0
    .row.row-cols-1.row-cols-md-3.g-4.mb-5
      each pub in descubri
        +tarjeta(pub)
  else
    p.text-muted Aún no hay publicaciones para descubrir.
