html
  head
    title Home - Fotaza
  body
    h1 Bienvenido #{usuario.nombre}!
    if exito
      p(style='color:green') ✅ ¡Publicación creada exitosamente!
    if error
      p(style='color:red') ❌ Error al crear la publicación
    p Estás logueado correctamente
    a(href='/publicacion/nueva') Crear nueva publicación
    br
    a(href='/logout') Cerrar sesión

    hr

    h2 ⭐ Destacadas
    if destacadas && destacadas.length > 0
      div
        each pub in destacadas
          div(style='border:1px solid #ccc; margin:10px; padding:10px')
            h3= pub.titulo
            img(src=pub.foto width='200')
            p Promedio: #{parseFloat(pub.promedio).toFixed(1)} ⭐ (#{pub.total_votos} votos)
    else
      p Aún no hay publicaciones destacadas.

    hr

    h2 🕐 Recientes
    if recientes && recientes.length > 0
      div
        each pub in recientes
          div(style='border:1px solid #ccc; margin:10px; padding:10px')
            h3= pub.titulo
            img(src=pub.foto width='200')
            p Promedio: #{parseFloat(pub.promedio).toFixed(1)} ⭐ (#{pub.total_votos} votos)
    else
      p Aún no hay publicaciones recientes.

    hr

    h2 🔍 Descubrí más
    if descubri && descubri.length > 0
      div
        each pub in descubri
          div(style='border:1px solid #ccc; margin:10px; padding:10px')
            h3= pub.titulo
            img(src=pub.foto width='200')
            p Promedio: #{parseFloat(pub.promedio).toFixed(1)} ⭐ (#{pub.total_votos} votos)
    else
      p Aún no hay publicaciones para descubrir.